# Server-side only. Never expose these values in VITE_* variables.
OPENROUTER_API_KEY=
# Use any OpenRouter chat/completion model ID. Rerank, embedding, and moderation-only models will not work here.
OPENROUTER_MODEL=
# Set to "off" for models that do not support JSON mode.
OPENROUTER_JSON_MODE=json_object
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_SITE_NAME=TerraRisk AI

# Optional provider adapters. Each URL can accept ?lat=...&lon=... and return JSON,
# or use {lat}, {lon}, {state}, {county}, {startDate}, and {endDate} URL tokens.
# The national CSIR/SANBI wildfire layer is used by default for the South Africa prototype.
TERRARISK_WILDFIRE_ARCGIS_URL=https://bgismaps.sanbi.org/server/rest/services/BGIS_Projects/2010VeldFireRisk2/MapServer/0/query
TERRARISK_FLOOD_URL=
TERRARISK_CRIME_URL=
TERRARISK_US_CRIME_URL=
# Optional credentials for the custom crime provider. Defaults to x-api-key when a key is set.
TERRARISK_CRIME_API_KEY=
TERRARISK_CRIME_AUTH_HEADER=x-api-key
TERRARISK_US_CRIME_API_KEY=
TERRARISK_US_CRIME_AUTH_HEADER=x-api-key
# South Africa: historical SAPS station totals from openAFRICA. Set the stats URL to
# "off" to disable the built-in adapter, or override either URL with a maintained mirror.
TERRARISK_ZA_CRIME_STATS_URL=https://open.africa/dataset/9cefda6a-f897-4c1a-8f37-0666d2410696/resource/786ddfdb-c192-4fab-bb47-ea41f00cc3cb/download/policestatistics_2005-2018.csv
TERRARISK_ZA_POLICE_STATIONS_URL=https://data.code4sa.org/api/views/jxjg-hd2g/rows.json?accessType=DOWNLOAD
# Optional built-in U.S. point/radius provider. Set this key to enable the CrimeoMeter adapter.
# When present, it takes priority over TERRARISK_US_CRIME_URL for U.S. analyses.
CRIMEOMETER_API_KEY=
# Use 1 for the Apiary evaluation documentation; use 2 for the current CrimeoMeter stats API.
CRIMEOMETER_API_VERSION=1
CRIMEOMETER_DISTANCE=3mi
TERRARISK_CLAIMS_URL=

# U.S. profile defaults. Override only if you have a more local/authoritative layer.
TERRARISK_US_WILDFIRE_ARCGIS_URL=https://services.arcgis.com/jIL9msH9OI208GCb/ArcGIS/rest/services/USA_Wildfire_Hazard_Potential/FeatureServer/6/query
TERRARISK_US_FIRE_HISTORY_ARCGIS_URL=https://services3.arcgis.com/T4QMspbfLg3qTGWY/arcgis/rest/services/InterAgencyFirePerimeterHistory_All_Years_View/FeatureServer/0/query
TERRARISK_US_FLOOD_ARCGIS_URL=https://hazards.fema.gov/arcgis/rest/services/public/NFHL/MapServer/28/query
TERRARISK_US_RISK_ARCGIS_URL=https://services.arcgis.com/PcBYuZP9vTIZ3FcN/ArcGIS/rest/services/FEMA_National_Risk_Index/FeatureServer/0/query

# Optional: comma-separated public listing hosts TerraRisk is allowed to read.
# Listing intake reads only publicly exposed HTML metadata and does not follow redirects.
# Country lists are merged for validation and shown separately in the listing info panel.
TERRARISK_ZA_LISTING_HOSTS=property24.com,privateproperty.co.za,pamgolding.co.za,seef.co.za
TERRARISK_US_LISTING_HOSTS=realtor.com,homes.com,compass.com
TERRARISK_LISTING_HOSTS=
